{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/*.php",
      "use": "@vercel/php"
    },
    {
      "src": "backend/*.php",
      "use": "@vercel/php"
    }
  ],
  "routes": [
    {
      "src": "/backend/(.*)",
      "dest": "/backend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
